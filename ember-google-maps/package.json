{
  "name": "ember-google-maps",
  "version": "7.0.0",
  "description": "Add Google Maps to your Ember app declaratively.",
  "keywords": [
    "ember-addon"
  ],
  "repository": "",
  "license": "MIT",
  "author": "",
  "imports": {
    "#src/*": "./src/*"
  },
  "exports": {
    ".": {
      "default": "./dist/index.js"
    },
    "./addon-main.js": "./addon-main.cjs",
    "./*.css": "./dist/*.css",
    "./*": {
      "default": "./dist/*.js"
    }
  },
  "files": [
    "addon-main.cjs",
    "declarations",
    "dist",
    "src"
  ],
  "scripts": {
    "build": "rollup --config",
    "format": "prettier . --cache --write",
    "lint": "concurrently \"pnpm:lint:*(!fix)\" --names \"lint:\" --prefixColors auto",
    "lint:fix": "concurrently \"pnpm:lint:*:fix\" --names \"fix:\" --prefixColors auto && pnpm run format",
    "lint:format": "prettier . --cache --check",
    "lint:hbs": "ember-template-lint . --no-error-on-unmatched-pattern",
    "lint:hbs:fix": "ember-template-lint . --fix --no-error-on-unmatched-pattern",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "lint:publish": "pnpm build && publint run --level error",
    "prepack": "rollup --config",
    "start": "vite dev",
    "test": "vite build --mode=development --out-dir dist-tests && testem --file testem.cjs ci --port 0"
  },
  "sideEffects": [
    "./src/setup.js",
    "./dist/setup.js"
  ],
  "dependencies": {
    "@ember/string": "^4.0.0",
    "@ember/test-waiters": "^4.0.0",
    "@embroider/addon-shim": "^1.8.9",
    "@embroider/macros": "^1.20.5",
    "decorator-transforms": "^2.2.2",
    "ember-modifier": "^4.3.0",
    "ember-provide-consume-context": "0.10.0",
    "rsvp": "^4.8.5"
  },
  "peerDependencies": {
    "@ember/test-helpers": ">= 3.0.0",
    "ember-source": ">= 5.12.0"
  },
  "peerDependenciesMeta": {
    "@ember/test-helpers": {
      "optional": true
    }
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/eslint-parser": "^7.25.1",
    "@babel/plugin-proposal-decorators": "^8.0.2",
    "@babel/runtime": "^7.25.6",
    "@ember/app-tsconfig": "^1.0.0",
    "@ember/library-tsconfig": "^1.0.0",
    "@ember/test-helpers": "^5.2.1",
    "@embroider/addon-dev": "^8.1.0",
    "@embroider/compat": "^4.1.0",
    "@embroider/core": "^4.1.0",
    "@embroider/vite": "^1.1.5",
    "@eslint/js": "^9.17.0",
    "@glimmer/component": "^2.0.0",
    "@rollup/plugin-babel": "^6.0.4",
    "babel-plugin-ember-template-compilation": "^4.0.0",
    "concurrently": "^9.0.1",
    "ember-page-title": "^9.0.3",
    "ember-qunit": "^9.0.2",
    "ember-source": "~6.12.0",
    "ember-strict-application-resolver": "^0.1.0",
    "ember-template-lint": "^7.9.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-ember": "^12.3.3",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-n": "^17.15.1",
    "globals": "^16.1.0",
    "prettier": "^3.4.2",
    "prettier-plugin-ember-template-tag": "^2.0.4",
    "publint": "^0.3.16",
    "qunit": "^2.24.1",
    "qunit-dom": "^3.4.0",
    "rollup": "^4.22.5",
    "testem": "^3.15.1",
    "vite": "^7.1.9"
  },
  "ember": {
    "edition": "octane"
  },
  "ember-addon": {
    "version": 2,
    "type": "addon",
    "main": "addon-main.cjs",
    "app-js": {
      "./components/g-map.js": "./dist/_app_/components/g-map.js",
      "./components/g-map/advanced-marker.js": "./dist/_app_/components/g-map/advanced-marker.js",
      "./components/g-map/autocomplete.js": "./dist/_app_/components/g-map/autocomplete.js",
      "./components/g-map/bicycling-layer.js": "./dist/_app_/components/g-map/bicycling-layer.js",
      "./components/g-map/canvas.js": "./dist/_app_/components/g-map/canvas.js",
      "./components/g-map/circle.js": "./dist/_app_/components/g-map/circle.js",
      "./components/g-map/control.js": "./dist/_app_/components/g-map/control.js",
      "./components/g-map/info-window.js": "./dist/_app_/components/g-map/info-window.js",
      "./components/g-map/map-component.js": "./dist/_app_/components/g-map/map-component.js",
      "./components/g-map/marker.js": "./dist/_app_/components/g-map/marker.js",
      "./components/g-map/overlay.js": "./dist/_app_/components/g-map/overlay.js",
      "./components/g-map/polygon.js": "./dist/_app_/components/g-map/polygon.js",
      "./components/g-map/polyline.js": "./dist/_app_/components/g-map/polyline.js",
      "./components/g-map/rectangle.js": "./dist/_app_/components/g-map/rectangle.js",
      "./components/g-map/traffic-layer.js": "./dist/_app_/components/g-map/traffic-layer.js",
      "./components/g-map/transit-layer.js": "./dist/_app_/components/g-map/transit-layer.js",
      "./components/g-map/typical-map-component.js": "./dist/_app_/components/g-map/typical-map-component.js",
      "./components/gmap-advanced-marker.js": "./dist/_app_/components/gmap-advanced-marker.js",
      "./components/gmap-autocomplete.js": "./dist/_app_/components/gmap-autocomplete.js",
      "./components/gmap-bicycling-layer.js": "./dist/_app_/components/gmap-bicycling-layer.js",
      "./components/gmap-canvas.js": "./dist/_app_/components/gmap-canvas.js",
      "./components/gmap-circle.js": "./dist/_app_/components/gmap-circle.js",
      "./components/gmap-control.js": "./dist/_app_/components/gmap-control.js",
      "./components/gmap-info-window.js": "./dist/_app_/components/gmap-info-window.js",
      "./components/gmap-marker.js": "./dist/_app_/components/gmap-marker.js",
      "./components/gmap-overlay.js": "./dist/_app_/components/gmap-overlay.js",
      "./components/gmap-polygon.js": "./dist/_app_/components/gmap-polygon.js",
      "./components/gmap-polyline.js": "./dist/_app_/components/gmap-polyline.js",
      "./components/gmap-rectangle.js": "./dist/_app_/components/gmap-rectangle.js",
      "./components/gmap-traffic-layer.js": "./dist/_app_/components/gmap-traffic-layer.js",
      "./components/gmap-transit-layer.js": "./dist/_app_/components/gmap-transit-layer.js",
      "./modifiers/g-map/did-insert.js": "./dist/_app_/modifiers/g-map/did-insert.js",
      "./services/google-maps-api.js": "./dist/_app_/services/google-maps-api.js"
    }
  }
}
